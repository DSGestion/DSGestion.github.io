    <script>
        function toggleMenu() {
            document.getElementById('mainNav').classList.toggle('open');
        }

        function showExportDay(idx) {
            document.querySelectorAll(".export-day-table").forEach(t => t.classList.remove("active"));
            document.querySelectorAll(".export-day-tab").forEach(b => b.classList.remove("active"));
            const table = document.getElementById("day-table-" + idx);
            const tab = document.getElementById("export-tab-" + idx);
            if(table) table.classList.add("active");
            if(tab) tab.classList.add("active");
        }

        function filterExportPlanning() {
            const query = document.getElementById("exportSearch").value.toLowerCase();
            document.querySelectorAll(".card-planned").forEach(card => {
                const searchText = card.getAttribute("data-search") || "";
                if (query === "" || searchText.includes(query)) {
                    card.style.display = "";
                } else {
                    card.style.display = "none";
                }
            });
        }

        // Afficher le premier jour par défaut
        if(document.querySelectorAll(".export-day-tab").length > 0) {
            showExportDay(0);
        }
    </script>
